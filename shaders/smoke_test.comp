#version 450

// Smoke-test shader: every invocation writes 42 into output[globalID].
// CPU reads back the buffer and asserts all values == 42.

layout(local_size_x = 64) in;

layout(set = 0, binding = 0) buffer Output {
    uint data[];
} out_buf;

layout(push_constant) uniform PC {
    uint count;
} pc;

void main() {
    uint id = gl_GlobalInvocationID.x;
    if (id >= pc.count) return;
    out_buf.data[id] = 42u;
}
